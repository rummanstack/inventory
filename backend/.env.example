PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventory

# Photo storage: local (default) or s3
PHOTO_STORAGE_DRIVER=local
BACKUP_STORAGE_DRIVER=local

# Required only when PHOTO_STORAGE_DRIVER=s3
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-private-photo-bucket
AWS_S3_PHOTO_PREFIX=photos
# HTTPS URL of a CloudFront distribution connected to the private S3 bucket.
AWS_S3_PUBLIC_BASE_URL=https://your-distribution.cloudfront.net

# Required only when BACKUP_STORAGE_DRIVER=s3. Keep this bucket/prefix private.
# AWS_S3_BACKUP_BUCKET defaults to AWS_S3_BUCKET when omitted.
AWS_S3_BACKUP_BUCKET=your-private-backup-bucket
AWS_S3_BACKUP_PREFIX=database-backups

# Local development only. In AWS, prefer an IAM role attached to the workload.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
